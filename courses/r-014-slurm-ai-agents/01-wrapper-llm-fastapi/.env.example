# Copy to .env and fill in the real key: cp .env.example .env
# OpenRouter key (required). Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — defaults live in app/core/config.py
# OPENROUTER_MODEL=openai/gpt-4o-mini
# APP_ENV=local

# Optional OpenRouter attribution headers (shown on the OpenRouter dashboard)
