# Copy to .env and fill in real values:  cp .env.example .env   (.env is gitignored)

# OpenRouter API key — the LiteLLM proxy uses it to reach models.
# Get one: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Virtual key the SDK presents to the proxy as ANTHROPIC_API_KEY. Any strong random
# string — it gates the local proxy, it is NOT an OpenRouter/Anthropic key.
LITELLM_MASTER_KEY=

# Local dev only: absolute path to the scoped read-only SA kubeconfig, so the get_pod
# tool's `kubectl` runs AS the read-only ServiceAccount (not your admin context). Mint it
# with: kubectl create token incident-agent -n incident-agent-sandbox --duration=8h
# In a Pod this is unset — the mounted SA is used instead (dev/prod parity).
# KUBECONFIG=/abs/path/to/kubeconfig-agent.yaml
