# Copy to .env and fill in real values:  cp .env.example .env   (.env is gitignored)

# OpenRouter API key — the LiteLLM proxy uses it to reach models.
# Get one: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Virtual key the SDK presents to the proxy as ANTHROPIC_API_KEY. Any strong random
# string — it gates the local proxy, it is NOT an OpenRouter/Anthropic key.
LITELLM_MASTER_KEY=
